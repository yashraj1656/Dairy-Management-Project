# .env.example
# Copy this file to .env and change the values for production

# Database configuration (Use PostgreSQL for production)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Security - Generate a secure key using `openssl rand -hex 32`
SECRET_KEY=your_secure_random_string

# CORS Configuration - Add your frontend URL
CORS_ORIGINS=["https://app.dairysync.com", "http://127.0.0.1:3000", "http://localhost:3000"]
